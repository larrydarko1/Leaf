{
  "name": "leaf",
  "private": true,
  "version": "1.4.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vue-tsc -b && vite build",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "jszip": "^3.10.1",
    "marked": "^17.0.1",
    "node-llama-cpp": "^3.15.1",
    "onnxruntime-node": "^1.24.2",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "jsdom": "^26.1.0",
    "sass-embedded": "^1.92.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10",
    "wait-on": "^9.0.3"
  },
  "description": "A local-first, privacy-focused note-taking app for desktop with built-in AI assistance. Simple interface for reading and editing txt and md files, plus support for loading local LLMs (GGUF format) for private, on-device chat and assistance. All notes and AI interactions stay on your device.",
  "author": "Lorenzo Mazzola",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/larrydarko1/leaf.git"
  },
  "build": {
    "appId": "com.leaf.app",
    "productName": "Leaf",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      "models/**"
    ],
    "asarUnpack": [
      "models/**"
    ],
    "dmg": {
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "iconSize": 100,
      "iconTextSize": 14,
      "title": "${productName} ${version}",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 260
        },
        {
          "x": 480,
          "y": 260,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "sign": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}