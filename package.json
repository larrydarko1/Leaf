{
    "name": "leaf",
    "version": "2.1.0",
    "description": "A local-first, privacy-focused note-taking app for desktop with built-in AI assistance. Simple interface for reading and editing txt and md files, plus support for loading local LLMs (GGUF format) for private, on-device chat and assistance. All notes and AI interactions stay on your device.",
    "keywords": [
        "notes",
        "markdown",
        "electron",
        "local-ai",
        "llm",
        "privacy"
    ],
    "homepage": "https://github.com/larrydarko1/leaf#readme",
    "bugs": {
        "url": "https://github.com/larrydarko1/leaf/issues"
    },
    "license": "AGPL-3.0-only",
    "author": "Lorenzo Mazzola",
    "type": "module",
    "main": "out/main/index.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/larrydarko1/leaf.git"
    },
    "scripts": {
        "dev": "electron-vite dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "build": "vue-tsc -b && electron-vite build",
        "build:electron": "npm run build && electron-builder",
        "build:mac": "npm run build && electron-builder --mac --publish never",
        "build:win": "npm run build && electron-builder --win --publish never",
        "build:linux": "npm run build && electron-builder --linux --publish never",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
        "stylelint": "stylelint \"src/**/*.{scss,vue}\"",
        "stylelint:fix": "stylelint \"src/**/*.{scss,vue}\" --fix",
        "prepare": "husky",
        "ci:check": "npm audit --audit-level=high --omit=dev && npm run lint && npm run format:check && npm run stylelint && npm test && npm run build"
    },
    "dependencies": {
        "vue": "^3.5.17",
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/language-data": "^6.5.2",
        "@codemirror/search": "^6.6.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.0",
        "@lezer/highlight": "^1.2.3",
        "@lezer/markdown": "^1.6.3",
        "marked": "^17.0.1",
        "node-llama-cpp": "^3.15.1",
        "onnxruntime-node": "^1.24.2",
        "@huggingface/transformers": "^3.8.1",
        "electron-log": "~5.4.3"
    },
    "devDependencies": {
        "typescript": "~6.0.2",
        "@types/node": "^24.0.13",
        "@vue/tsconfig": "^0.9.0",
        "vue-tsc": "^3.2.0",
        "vite": "^7.0.0",
        "@vitejs/plugin-vue": "^6.0.6",
        "electron-vite": "^5.0.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.4.0",
        "@vue/test-utils": "^2.4.6",
        "vitest": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.0",
        "jsdom": "^26.1.0",
        "eslint": "^10.0.3",
        "@eslint/js": "^10.0.1",
        "typescript-eslint": "^8.58.1",
        "eslint-plugin-vue": "^10.8.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "stylelint": "^17.13.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "postcss-html": "^1.8.1",
        "sass-embedded": "^1.87.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0"
    },
    "engines": {
        "node": ">=20",
        "npm": ">=10"
    },
    "private": true,
    "packageManager": "npm@11.11.0",
    "build": {
        "appId": "com.leaf.app",
        "productName": "Leaf",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "package.json",
            {
                "from": "out",
                "to": "out",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "afterPack": "./build/afterPack.cjs",
        "extraResources": [
            "models/**",
            "assets/**"
        ],
        "asarUnpack": [
            "models/**",
            "node_modules/onnxruntime-node/**"
        ],
        "dmg": {
            "background": "build/dmg-background.png",
            "icon": "build/icon.icns",
            "iconSize": 100,
            "iconTextSize": 14,
            "title": "${productName} ${version}",
            "window": {
                "width": 660,
                "height": 400
            },
            "contents": [
                {
                    "x": 180,
                    "y": 260
                },
                {
                    "x": 480,
                    "y": 260,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "mac": {
            "category": "public.app-category.productivity",
            "identity": null,
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.icns"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icon.ico"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Utility"
        }
    },
    "lint-staged": {
        "*.{ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{scss,vue}": [
            "stylelint --fix"
        ],
        "*.{scss,json,md}": [
            "prettier --write"
        ]
    }
}
